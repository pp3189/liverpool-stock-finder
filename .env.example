# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Estrategia anti-bot para producción:
# En Render/live, usa de preferencia un worker/API externo con navegador real,
# proxy residencial o proveedor oficial de datos. La app enviará POST JSON y
# espera una respuesta con { "tiendas": [...] }.
AMAZON_EXTERNAL_URL=""
AMAZON_EXTERNAL_TOKEN=""
AMAZON_EXTERNAL_FALLBACK_DIRECT="true"
AMAZON_EXTERNAL_TIMEOUT_MS="45000"

# SerpApi para Amazon Mexico. Configura la llave real en Render, no en git.
SERPAPI_API_KEY=""
SERPAPI_AMAZON_DOMAIN="amazon.com.mx"
SERPAPI_NO_CACHE="false"
SERPAPI_FALLBACK_DIRECT="false"
SERPAPI_TIMEOUT_MS="45000"

SAMS_EXTERNAL_URL=""
SAMS_EXTERNAL_TOKEN=""
SAMS_EXTERNAL_FALLBACK_DIRECT="true"
SAMS_EXTERNAL_TIMEOUT_MS="60000"

# Fallback directo de Sam's. En Render déjalo desactivado salvo que la imagen
# tenga navegadores Playwright instalados y el sitio permita sesiones headless.
SAMS_AUTO_REFRESH="false"
SAMS_HEADLESS="true"
SAMS_BROWSER_CHANNEL=""
SAMS_COOKIE_STRING=""
SAMS_COOKIE_TTL_MS="5400000"
